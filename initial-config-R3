hostname R3
ip domain-name lab.local
username ansible privilege 15 secret ansible123
!
interface GigabitEthernet0/0
 description MGMT
 ip address 192.168.100.13 255.255.255.0
 no shutdown
!
crypto key generate rsa modulus 2048
ip ssh version 2
!
line vty 0 4
 login local
 transport input ssh
!
end
write memory
